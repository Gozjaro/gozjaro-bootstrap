# Gozjaro LFS build environment.
# Sourced by build.sh and by the lfs user's ~/.bash_profile / ~/.bashrc.

# Use `=` (not `:=`) so an intentionally-empty LFS (inside chroot) is preserved.
: "${LFS=/mnt/lfs}"
: "${LFS_TGT=$(uname -m)-gozjaro-linux-gnu}"
: "${LC_ALL:=POSIX}"

# Distro identity (used in /etc, inittab banner, etc.)
DISTRO_NAME="Gozjaro"
DISTRO_ID="gozjaro"
DISTRO_VERSION="0.1"

# LFS book version this tree targets.
LFS_BOOK_VERSION="12.3"

# Upstream URLs used by 20-fetch-sources.sh. Refresh these from the book
# when bumping LFS_BOOK_VERSION (see README "Refreshing packages").
LFS_WGET_LIST_URL="https://www.linuxfromscratch.org/lfs/view/${LFS_BOOK_VERSION}/wget-list-sysv"
LFS_MD5_URL="https://www.linuxfromscratch.org/lfs/view/${LFS_BOOK_VERSION}/md5sums"

# Parallelism
: "${MAKEFLAGS:=-j$(nproc 2>/dev/null || echo 2)}"
: "${PARALLEL_DOWNLOADS:=4}"

# Derived paths
STATE_DIR="${LFS}/var/gozjaro/state"
LOG_DIR="${LFS}/var/gozjaro/log"
SOURCES_DIR="${LFS}/sources"

export LFS LFS_TGT LC_ALL MAKEFLAGS
export DISTRO_NAME DISTRO_ID DISTRO_VERSION LFS_BOOK_VERSION
export STATE_DIR LOG_DIR SOURCES_DIR
